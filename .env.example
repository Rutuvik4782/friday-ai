# =============================================================================
# F.R.I.D.A.Y. — Environment Variables
# Fill in your API keys below. Copy this file to .env
# =============================================================================

# -----------------------------------------------------------------------------
# PROVIDER SELECTION — choose free or paid options
# -----------------------------------------------------------------------------
# STT:  sarvam (paid) | whisper (OpenAI, paid) | deepgram (paid)
# LLM:  groq   (FREE ✓) | gemini (free tier) | openai (paid)
# TTS:  gtts   (FREE ✓) | sarvam (paid) | openai (paid)

STT_PROVIDER=sarvam
LLM_PROVIDER=groq
TTS_PROVIDER=gtts

# Groq free models: llama-3.3-70b-versatile, mixtral-8x7b-32768, llama-3.1-8b-instant
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Gemini free model at aistudio.google.com
GEMINI_LLM_MODEL=gemini-2.0-flash

# OpenAI paid models
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
TTS_SPEED=1.15

# gTTS free TTS language
GTTS_LANG=en

# Port for MCP server
MCP_SERVER_PORT=8000

# -----------------------------------------------------------------------------
# API KEYS
# -----------------------------------------------------------------------------

# Groq API key — FREE tier at https://console.groq.com
GROQ_API_KEY=

# Sarvam AI API key — https://dashboard.sarvam.ai
SARVAM_API_KEY=

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google API key — https://aistudio.google.com (free tier)
GOOGLE_API_KEY=

# Deepgram API key — https://console.deepgram.com
DEEPGRAM_API_KEY=

# Google Cloud credentials (only if using GCP STT)
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# LIVEKIT — for voice agent
# Get free project at https://cloud.livekit.io
# -----------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# SUPABASE — for ticketing system (optional)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co/rest/v1
SUPABASE_API_KEY=your-supabase-api-key

# -----------------------------------------------------------------------------
# MCP SERVER OVERRIDE
# If deploying MCP server elsewhere, set this to its base URL
# e.g. https://your-worker.your-account.workers.dev
# Leave empty for local (127.0.0.1)
# -----------------------------------------------------------------------------
MCP_SERVER_URL=
